# ─── 必須設置 ───

# The Odds API — 即時市場賠率
# 申請：https://the-odds-api.com/#get-access
# Free plan: 500 credits/月
ODDS_API_KEY=your_odds_api_key_here

# 26worldcup.cn — 世界盃賽程/賽果數據中心
# 申請：https://www.26worldcup.cn — Register → Email 獲取 API Key
WORLDCUP26_API_KEY=your_worldcup26_api_key_here

# ─── 可選設置 ───

# 彩雲天氣 API（用於天氣預警模塊）
# 申請：https://dashboard.caiyunapp.com/
CAIYUN_WEATHER_TOKEN=your_caiyun_weather_token_here

# 彩雲小譯 API（用於翻譯）
CAIYUN_TRANSLATE_TOKEN=your_caiyun_translate_token_here
